---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
}

const { title, description, date, category, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const isAccent = category === 'réflexions';
---

<a href={`/blog/${slug}`} class="article-card">
  <div class="article-card__top">
    <span class={`tag ${isAccent ? 'tag--accent' : ''}`}>{category}</span>
    <span class="article-card__date">{formattedDate}</span>
  </div>
  <h2 class="article-card__title">{title}</h2>
  <p class="article-card__excerpt">{description}</p>
</a>

<style>
  .article-card {
    display: block;
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .article-card:hover {
    border-color: var(--color-border-mid);
  }
  .article-card__top {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 0.6rem;
  }
  .article-card__date {
    font-size: 12px;
    color: var(--color-text-subtle);
  }
  .article-card__title {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }
  .article-card__excerpt {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
</style>
