---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Accueil">
  <section style="margin-bottom: 3rem;">
    <div style="width: 28px; height: 2px; background: var(--color-accent); border-radius: 1px; margin-bottom: 1rem;"></div>
    <h1 style="font-size: clamp(24px, 5vw, 36px); font-weight: 600; letter-spacing: -0.04em; line-height: 1.2; margin-bottom: 0.75rem;">
      Développeur senior —<br>architecture &amp; backend.
    </h1>
    <p style="font-size: 16px; color: var(--color-text-muted); line-height: 1.7; max-width: 480px;">
      Je partage mes réflexions sur les systèmes distribués, le craft logiciel et les décisions d'architecture qu'on prend rarement deux fois de la même façon.
    </p>
  </section>

  <section>
    <p style="font-size: 11px; letter-spacing: 0.07em; text-transform: uppercase; color: var(--color-text-subtle); font-weight: 500; margin-bottom: 1.25rem;">
      Derniers articles
    </p>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px;">
      {posts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.excerpt}
          date={post.data.date}
          category={post.data.category}
          slug={post.id}
        />
      ))}
    </div>
    <div style="margin-top: 1.5rem;">
      <a href="/blog" style="font-size: 13px; color: var(--color-text-muted); text-decoration: none;">
        Tous les articles →
      </a>
    </div>
  </section>
</Base>
