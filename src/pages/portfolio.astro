---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'Projet A',
    description: 'Description courte du projet et de ce qu\'il résout.',
    stack: ['TypeScript', 'Node.js', 'PostgreSQL'],
    github: 'https://github.com/votre-username/projet-a',
  },
  {
    name: 'Projet B',
    description: 'Description courte du projet et de ce qu\'il résout.',
    stack: ['Kafka', 'Redis', 'Docker'],
    github: 'https://github.com/votre-username/projet-b',
  },
];
---

<Base title="Portfolio — Sébastien JAUPART">
  <section>
    <div style="width: 28px; height: 2px; background: var(--accent); border-radius: 1px; margin-bottom: 1rem;"></div>
    <h1 style="font-size: 26px; font-weight: 600; letter-spacing: -0.03em; margin-bottom: 0.75rem;">Portfolio</h1>
    <p style="font-size: 15px; color: var(--color-text-muted); margin-bottom: 2.5rem; line-height: 1.7;">
      Projets personnels et contributions open source.
    </p>

    <div style="display: flex; flex-direction: column; gap: 12px;">
      {projects.map(p => (
        <a href={p.github} target="_blank" rel="noopener" style="display: block; padding: 1.25rem; border: 0.5px solid var(--color-border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s;">
          <p style="font-size: 15px; font-weight: 500; color: var(--color-text); margin-bottom: 0.35rem;">{p.name}</p>
          <p style="font-size: 13px; color: var(--color-text-muted); margin-bottom: 0.75rem; line-height: 1.55;">{p.description}</p>
          <div style="display: flex; gap: 6px; flex-wrap: wrap;">
            {p.stack.map(s => (
              <span style="font-size: 11px; padding: 2px 8px; background: var(--color-surface); border: 0.5px solid var(--color-border); border-radius: 4px; color: var(--color-text-muted);">{s}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
