---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — Sébastien JAUPART">
  <section>
    <div style="width: 28px; height: 2px; background: var(--accent); border-radius: 1px; margin-bottom: 1rem;"></div>
    <h1 style="font-size: 26px; font-weight: 600; letter-spacing: -0.03em; margin-bottom: 0.75rem;">Contact</h1>
    <p style="font-size: 15px; color: var(--color-text-muted); margin-bottom: 2.5rem; line-height: 1.7;">
      Pour discuter d'un projet, d'une opportunité, ou juste échanger sur un article.
    </p>

    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <a href="https://github.com/sjaupart" target="_blank" rel="noopener" style="font-size: 15px; color: var(--color-text); text-decoration: none; display: flex; align-items: center; gap: 10px; padding: 1rem 1.25rem; border: 0.5px solid var(--color-border); border-radius: var(--radius-lg); transition: border-color 0.15s;">
        <span style="color: var(--color-text-faint); font-size: 13px;">GitHub</span>
        github.com/sjaupart
      </a>
      <a href="https://fr.linkedin.com/in/sebastien-jaupart" target="_blank" rel="noopener" style="font-size: 15px; color: var(--color-text); text-decoration: none; display: flex; align-items: center; gap: 10px; padding: 1rem 1.25rem; border: 0.5px solid var(--color-border); border-radius: var(--radius-lg); transition: border-color 0.15s;">
        <span style="color: var(--color-text-faint); font-size: 13px;">LinkedIn</span>
        fr.linkedin.com/in/sebastien-jaupart
      </a>
    </div>
  </section>
</Base>
